<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.attendancesystem.mapper.PositionMapper">

    <resultMap id="PositionResultMap" type="com.example.attendancesystem.entity.Position">
        <id property="id" column="id"/>
        <result property="positionName" column="position_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="PositionResultMap">
        SELECT id, position_name, status, created_at, updated_at
        FROM position
        ORDER BY id
    </select>
</mapper>
